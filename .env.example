# PostgreSQL
POSTGRES_PASSWORD=postgres

# JWT signing key — must be at least 32 characters
JWT_SIGNING_KEY=change-me-to-a-secure-random-string-at-least-32-chars

# Google OAuth client IDs (optional for local dev without Google login)
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# Gemini API — used by the voice assistant feature
# Get a key at https://aistudio.google.com/app/apikey
Gemini__ApiKey=
Gemini__Model=gemini-2.5-flash